PORT=3000
JWT_SECRET=internai_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
SCRAPE_INTERVAL_HOURS=6

# Turso (cloud SQLite) — required for Vercel deployment
# Sign up free at https://turso.tech
# Leave blank for local dev (uses local internai.db file instead)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
